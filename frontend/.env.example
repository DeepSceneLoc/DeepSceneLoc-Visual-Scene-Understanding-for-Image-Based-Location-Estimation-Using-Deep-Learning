# 🌏 DeepSceneLoc — Frontend Environment Configuration Example
# (Note: Vite loads environment variables from the parent directory's .env file)

# Google Gemini Native API Key (Used for Stage 2 location grounding / AI features)
GEMINI_API_KEY="your_gemini_api_key_here"

# Google Maps API Key (Used for interactive Google Maps / Street View in React frontend)
VITE_GOOGLE_MAPS_API_KEY="your_google_maps_api_key_here"

