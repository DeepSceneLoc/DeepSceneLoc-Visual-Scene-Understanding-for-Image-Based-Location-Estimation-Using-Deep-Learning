# DeepSceneLoc - Environment Configuration
# Copy this file to .env and replace the values with your actual keys

# Google Gemini API Key (Required for Phase 2 - Exact Location Detection)
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# FastAPI Server Port
PORT=8000
